// secrets.h — คัดลอกไฟล์นี้เป็น "secrets.h" (อยู่โฟลเดอร์เดียวกัน) แล้วเติมค่าจริง
//   cp secrets.h.example secrets.h
// secrets.h ถูก .gitignore ไว้แล้ว — ห้าม commit ค่าจริงเด็ดขาด
//
// service_role key = key ที่ bypass RLS ทั้งหมด (insert sensor_readings/actuator_events,
// update commands.acked_at) — เก็บบนอุปกรณ์ edge เท่านั้น ห้ามหลุดไปฝั่ง frontend/browser
// (ดู supabase/README.md "กฎเหล็ก")
// ============================================================================

// ---------- WiFi ----------
#define SECRET_WIFI_SSID   "CHANGEME"
#define SECRET_WIFI_PASS   "CHANGEME"

// ---------- Supabase (โหมด Internet) ----------
// Project URL จาก Supabase → Project Settings → API เช่น https://xxxxx.supabase.co
// (ไม่ต้องมี / ต่อท้าย)
#define SECRET_SUPABASE_URL          "https://CHANGEME.supabase.co"
// service_role key (JWT ยาว) จาก Project Settings → API → service_role — ห้ามใช้ anon key
#define SECRET_SUPABASE_SERVICE_KEY  "CHANGEME.service_role.jwt"
