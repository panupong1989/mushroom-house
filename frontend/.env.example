# URL ของ backend API (ดู backend/src/index.ts) — ต้องไม่มี / ต่อท้าย
# ถ้าไม่ตั้งค่านี้ (เช่น deploy preview บน Vercel แบบยังไม่มี backend) frontend จะเข้าโหมด mock อัตโนมัติ
# (ดู NEXT_PUBLIC_USE_MOCK ด้านล่าง + lib/mock.ts)
NEXT_PUBLIC_API_URL=http://localhost:3000

# house id ที่จะแสดงผล (ต้องตรงกับ HOUSE_ID ฝั่ง backend / seed.sql)
NEXT_PUBLIC_HOUSE_ID=house-01

# บังคับโหมด mock-data ตรงๆ: 'true' | 'false' — ถ้าเว้นว่างไว้ ค่าเริ่มต้นคือ
# true เมื่อไม่ได้ตั้ง NEXT_PUBLIC_API_URL (deploy Vercel preview แบบยังไม่มี backend)
# false เมื่อมี NEXT_PUBLIC_API_URL (ต่อ backend จริง)
NEXT_PUBLIC_USE_MOCK=
