# URL ของ backend API (ดู backend/src/index.ts) — ต้องไม่มี / ต่อท้าย
# ถ้าไม่ตั้งค่านี้ (เช่น deploy preview บน Vercel แบบยังไม่มี backend) frontend จะเข้าโหมด mock อัตโนมัติ
# (ดู NEXT_PUBLIC_USE_MOCK ด้านล่าง + lib/mock.ts)
NEXT_PUBLIC_API_URL=http://localhost:3000

# house id ที่จะแสดงผล (ต้องตรงกับ HOUSE_ID ฝั่ง backend / seed.sql)
NEXT_PUBLIC_HOUSE_ID=house-01

# บังคับโหมด mock-data ตรงๆ: 'true' | 'false' — ถ้าเว้นว่างไว้ ค่าเริ่มต้นคือ
# true เมื่อไม่ได้ตั้ง NEXT_PUBLIC_API_URL และไม่ได้ตั้ง Supabase ด้านล่าง (deploy Vercel preview
# แบบยังไม่มี backend/Supabase) false เมื่อมี NEXT_PUBLIC_API_URL หรือ Supabase (ต่อของจริง)
NEXT_PUBLIC_USE_MOCK=

# --- โหมด Internet (Supabase) — ดู supabase/README.md ---
# ตั้ง 2 ค่านี้แล้ว frontend จะสลับไปอ่าน/subscribe realtime จาก Supabase แทน backend/mock ทันที
# (ลำดับความสำคัญ: Supabase > NEXT_PUBLIC_API_URL > mock — ดู frontend/README.md)
# ใช้ "anon public" key เท่านั้น ห้ามใช้ service_role key ที่นี่เด็ดขาด (ค่า NEXT_PUBLIC_* ทุกตัว
# ถูกฝังในโค้ดที่ browser ดาวน์โหลดได้)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
