# --- Backend ---
PORT=3000
NODE_ENV=development

# --- PostgreSQL ---
DATABASE_URL=postgresql://mush:mushpass@localhost:5432/mushroom

# --- MQTT ---
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_BASE_TOPIC=mush

# --- House ---
HOUSE_ID=house-01

# --- CORS (frontend เรียก API ข้ามโดเมน เช่น frontend/backend คนละโดเมนบน Vercel) ---
# '*' = อนุญาตทุก origin (default, dev only) หรือระบุ origin จริงของ frontend คั่นด้วย ',' ได้หลายค่า
# เช่น https://myapp.vercel.app,https://myapp-preview.vercel.app
CORS_ORIGIN=*
